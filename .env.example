# FNOL Claims Processing Agent - Configuration Template
# Copy this file to .env and fill in actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fnol_claims
DB_USER=fnol_user
DB_PASSWORD=your_secure_password_here

# CRM API Configuration
CRM_API_BASE_URL=https://crm.company.internal
CRM_API_TOKEN=your_crm_bearer_token_here
CRM_API_TIMEOUT=5

# Policy SOAP API Configuration
POLICY_SOAP_URL=https://policy-admin.company.internal/soap/PolicyService
POLICY_SOAP_USERNAME=your_soap_username_here
POLICY_SOAP_PASSWORD=your_soap_password_here
POLICY_SOAP_TIMEOUT=8

# Notification Service Configuration
NOTIFICATION_API_BASE_URL=https://notifications.company.internal
NOTIFICATION_API_TOKEN=your_notification_token_here
NOTIFICATION_API_TIMEOUT=5

# Document Management System Configuration
DMS_API_BASE_URL=https://dms.company.internal
DMS_API_KEY=your_dms_api_key_here
DMS_API_TIMEOUT=10

# NLP/AI Configuration
# Options: openai, azure_openai, claude, local
NLP_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.1

# Application Configuration
APP_ENV=development
LOG_LEVEL=INFO
DEBUG_MODE=true

# Agent Behavior Configuration
EXTRACTION_CONFIDENCE_THRESHOLD=0.7
ROUTING_CONFIDENCE_THRESHOLD=0.8
SEVERITY_THRESHOLDS_LOW=5000
SEVERITY_THRESHOLDS_HIGH=50000
SEVERITY_THRESHOLDS_CRITICAL=100000

# Integration Configuration
ENABLE_MOCK_INTEGRATIONS=true
MOCK_CRM_API=true
MOCK_POLICY_SOAP=true
MOCK_NOTIFICATION_API=true
MOCK_DMS_API=true

# Monitoring and Alerting
ENABLE_METRICS=true
METRICS_PORT=9090
ALERT_EMAIL=ops-team@company.com

# Cache Configuration
ENABLE_POLICY_CACHE=true
POLICY_CACHE_TTL_SECONDS=3600
